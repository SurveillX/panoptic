<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Panoptic Daily Report — {{ serial_number }} — {{ window_start_utc[:10] }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
         max-width: 960px; margin: 2em auto; padding: 0 1em; color: #222; }
  h1 { font-size: 1.5em; border-bottom: 2px solid #333; padding-bottom: .3em; }
  h2 { font-size: 1.2em; margin-top: 1.8em; border-bottom: 1px solid #ccc; padding-bottom: .2em; }
  h3 { font-size: 1em; margin-top: 1em; }
  .meta { color: #666; font-size: .85em; margin-bottom: 1em; }
  .overall, .camera { background: #f7f7f7; padding: 1em 1.2em; border-left: 3px solid #555;
                       margin: 1em 0; border-radius: 2px; }
  .camera.low-confidence { border-left-color: #c88; }
  .headline { font-weight: 600; font-size: 1.05em; margin: 0 0 .4em 0; }
  .confidence { color: #666; font-size: .85em; }
  .events-table { border-collapse: collapse; width: 100%; margin: .8em 0; font-size: .9em; }
  .events-table th, .events-table td { text-align: left; padding: .3em .6em; border-bottom: 1px solid #eee; }
  .events-table th { background: #eee; }
  .images { display: flex; flex-wrap: wrap; gap: .6em; margin: .8em 0; }
  .images figure { margin: 0; width: 160px; font-size: .75em; color: #666; }
  .images img { width: 160px; height: 120px; object-fit: cover; border: 1px solid #ccc; border-radius: 2px; }
  .images figcaption { margin-top: .2em; line-height: 1.3; }
  .empty { color: #888; font-style: italic; }
  .footer { margin-top: 2em; padding-top: 1em; border-top: 1px solid #ccc; color: #888; font-size: .8em; }
  code { background: #eee; padding: 0 .3em; border-radius: 2px; font-size: .85em; }
</style>
</head>
<body>

<h1>Daily Report — {{ serial_number }}</h1>
<div class="meta">
  Window: <code>{{ window_start_utc }}</code> to <code>{{ window_end_utc }}</code> (UTC)<br>
  Generated: <code>{{ generated_at_utc }}</code><br>
  Report ID: <code>{{ report_id }}</code>
</div>

<h2>Overall</h2>
<div class="overall">
  <p class="headline">{{ overall.headline }}</p>
  <p>{{ overall.summary }}</p>
  <p class="confidence">
    Confidence: {{ "%.2f"|format(overall.confidence) }}
    {% if overall.supporting_camera_ids %}
      · Cameras referenced: {{ overall.supporting_camera_ids|join(", ") }}
    {% endif %}
  </p>
</div>

<h2>Coverage</h2>
<ul>
  <li>{{ camera_count }} camera{{ "" if camera_count == 1 else "s" }} with data in this window</li>
  <li>{{ summary_count }} source summaries considered</li>
  <li>{{ image_count }} images considered</li>
  <li>{{ event_count }} events considered</li>
</ul>

<h2>Per-camera</h2>
{% if per_camera %}
  {% for cam in per_camera %}
    <div class="camera {% if cam.confidence < 0.5 %}low-confidence{% endif %}">
      <h3>{{ cam.camera_id }}</h3>
      <p class="headline">{{ cam.headline }}</p>
      <p>{{ cam.summary }}</p>
      <p class="confidence">Confidence: {{ "%.2f"|format(cam.confidence) }}</p>

      {% if cam.images %}
        <div class="images">
          {% for img in cam.images %}
            <figure>
              <img src="{{ asset_url_prefix }}/{{ img.image_id }}.jpg" alt="image {{ img.image_id[:12] }}">
              <figcaption>
                <code>{{ img.trigger or "?" }}</code>
                {{ img.captured_at or img.bucket_start or "" }}<br>
                {{ img.caption_text or "(no caption)" }}
              </figcaption>
            </figure>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% endfor %}
{% else %}
  <p class="empty">No per-camera narratives were produced for this window.</p>
{% endif %}

<h2>Events ({{ event_count }})</h2>
{% if events %}
  <table class="events-table">
    <thead>
      <tr><th>When</th><th>Type</th><th>Source</th><th>Camera</th><th>Severity</th><th>Description</th></tr>
    </thead>
    <tbody>
      {% for ev in events %}
      <tr>
        <td>{{ ev.event_time_utc }}</td>
        <td>{{ ev.event_type }}</td>
        <td>{{ ev.event_source }}</td>
        <td>{{ ev.camera_id }}</td>
        <td>{% if ev.severity is not none %}{{ "%.2f"|format(ev.severity) }}{% else %}—{% endif %}</td>
        <td>{{ ev.title or "" }}{% if ev.description %} — {{ ev.description }}{% endif %}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
{% else %}
  <p class="empty">No events recorded in this window.</p>
{% endif %}

<div class="footer">
  Template {{ template_version }} · Panoptic M9 · {{ serial_number }}
</div>

</body>
</html>
