# Panoptic application environment — copy to .env and adjust.
# .env is gitignored; .env.example is checked in as a reference.

DATABASE_URL=postgresql://panoptic:changeme@panoptic-store:5432/panoptic
REDIS_URL=redis://panoptic-store:6379
QDRANT_URL=http://panoptic-store:6333

VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=gemma-4-26b-it

WEBHOOK_PORT=8100
IMAGE_STORAGE_ROOT=/data/panoptic-store/images
CUDA_VISIBLE_DEVICES=""

RETRIEVAL_BASE_URL=http://localhost:8700
RETRIEVAL_TIMEOUT_SEC=180

# --- HMAC auth (v2) ---
# Generate a strong active secret:  python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
PANOPTIC_SHARED_SECRET_ACTIVE=CHANGE-ME-GENERATE-A-STRONG-SECRET
# Set during overlap rotation only; unset when rollout completes.
# PANOPTIC_SHARED_SECRET_PREVIOUS=
PANOPTIC_AUTH_MAX_SKEW_SEC=300
PANOPTIC_AUTH_REPLAY_TTL_SEC=600
PANOPTIC_AUTH_REGISTRY_REFRESH_SEC=30
# dev-mode hatch — set BOTH to disable auth. Never in production.
# PANOPTIC_DEV_MODE=true
# PANOPTIC_AUTH_ENABLED=false

# --- health ports ---
CAPTION_HEALTH_PORT=8201
CAP_EMBED_HEALTH_PORT=8202
SUMMARY_HEALTH_PORT=8203
SUM_EMBED_HEALTH_PORT=8204
ROLLUP_HEALTH_PORT=8205
IMAGE_EMBED_HEALTH_PORT=8206
EVENT_PRODUCER_HEALTH_PORT=8207
RECLAIMER_HEALTH_PORT=8210
HEALTH_PROBE_INTERVAL_SEC=30
HEALTH_PROBE_TIMEOUT_SEC=5

# --- reclaimer ---
RECLAIMER_INTERVAL_SEC=30

# --- Search API retrieval mode (M5) ---
# caption | vl | hybrid — default hybrid merges caption-based and VL-native
# image retrieval. vl-only can be useful during debugging; caption-only is
# the legacy pre-M5 behavior.
# SEARCH_RETRIEVAL_MODE=hybrid

# --- Search API rerank mode (M5 polish) ---
# text (default) | vl
# text: final-pass image rerank uses the text reranker over caption_text.
# vl:   final-pass image rerank uses Qwen3-VL-Reranker-2B on actual pixels.
# On synthetic harness data, 'text' scores slightly better. On real
# surveillance imagery, 'vl' is materially better (0.83+ on exact matches
# vs ~0.70 with text). Flip when real data dominates the workload.
# SEARCH_RERANK_MODE=vl

# --- dev escape hatches ---
# Skip keyframe fetching from trailer Continuum URLs (useful for local dev
# where fake trailer hostnames SSL-timeout). All summaries run metadata_only.
# PANOPTIC_CONTINUUM_DISABLED=true

# Disable Search API startup warmup (pre-fires /embed and /rerank against the
# retrieval service to avoid the ~100s first-query torch.compile stall).
# SEARCH_API_WARMUP_DISABLED=true
